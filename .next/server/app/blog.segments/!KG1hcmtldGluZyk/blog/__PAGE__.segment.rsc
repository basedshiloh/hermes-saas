23:["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“I tried self-hosting Hermes Agent and gave up after fighting Docker configs for a weekend. Found this platform, deployed in one click, and never looked back.",["$","span",null,{"className":"mt-5 inline-block","children":"The auto-sleep feature means I only pay when I actually use it, which is way cheaper than keeping a VPS running 24/7.”"}]]}]}]
24:["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-avatar-6.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial four"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“I am a grad student using the Researcher Pack. My agent summarizes papers, extracts key findings, and even writes literature review drafts.",["$","span",null,{"className":"mt-5 inline-block","children":"It saved me easily 15 hours a week during thesis season. The chat interface is so simple — just ask and it does the work.”"}]]}]}]]}]
25:["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-avatar-7.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial five"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“The cron scheduling changed everything for me. I set my agent to pull competitor pricing every morning and compile a report before I wake up.",["$","span",null,{"className":"mt-5 inline-block","children":"As a solo e-commerce founder, having an AI analyst that runs on autopilot feels like having a full-time employee.”"}]]}]}]]}]
26:["$","$L20",null,{"children":[["$","$L21",null,{"src":"$b:props:children:props:children:props:children:0:props:children:props:children:0:props:children:0:props:children:props:children:0:0:props:children:props:src","alt":"testimonial six"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“What sold me was the container isolation. Each agent runs in its own sandbox, so I feel safe letting it execute code and manage files.",["$","span",null,{"className":"mt-5 inline-block","children":"I use the Engineer Pack and it helps me prototype scripts, debug APIs, and write documentation faster than I ever could alone.”"}]]}]}]]}]
27:["$","$L20",null,{"children":[["$","$L21",null,{"src":"$b:props:children:props:children:props:children:0:props:children:props:children:0:props:children:0:props:children:props:children:0:1:props:children:props:src","alt":"testimonial seven"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“Being able to switch between 200+ models with my own API key is incredible. I test different models for different tasks — Claude for writing, GPT for coding, Gemini for analysis.",["$","span",null,{"className":"mt-5 inline-block","children":"No other platform gives you this kind of flexibility without locking you into their own pricing.”"}]]}]}]]}]
28:["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-avatar-10.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial eight"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“I manage a small marketing team and set up agents for everyone using different Packs. Our SEO lead, content writer, and social manager each have their own agent tuned for their role.",["$","span",null,{"className":"mt-5 inline-block","children":"The skill system lets them teach their agents new tricks without any coding. Productivity across the board went through the roof.”"}]]}]}]]}]
