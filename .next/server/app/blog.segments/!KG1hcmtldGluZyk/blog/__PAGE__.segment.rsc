17:["$","$L2",null,{"delay":0.6,"children":["$","div",null,{"className":"col-span-12 lg:col-span-8","children":["$","$L1f",null,{"children":[["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-img-2.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial one"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“I run an SEO agency and had zero experience with AI agents or servers. I picked the SEO Manager Pack, clicked deploy, and had my agent running in under a minute.",["$","span",null,{"className":"mt-5 inline-block","children":"It now handles keyword research and content briefs while I focus on clients.”"}]]}]}]]}],["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-avatar-4.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial two"}],["$","$L22",null,{"children":["$","p",null,{"className":"text-secondary","children":["“As a freelance social media manager, I needed help writing captions and scheduling posts across platforms.",["$","span",null,{"className":"mt-5 inline-block","children":"My Hermes Agent drafts a full week of content in minutes. The BYOK model access means I can use whichever AI writes best for my niche.”"}]]}]}]]}],["$","$L20",null,{"children":[["$","$L21",null,{"src":{"src":"/_next/static/media/ns-avatar-5.a42e02b5.jpg","width":694,"height":694,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/jpeg;base64,"},"alt":"testimonial three"}],"$L23"]}],"$L24","$L25","$L26","$L27","$L28","$L29","$L2a"]}]}]}]
