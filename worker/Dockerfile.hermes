FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    curl \
    git \
    python3 \
    python3-pip \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash hermes

USER hermes
WORKDIR /home/hermes

RUN curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash || true

# Default to an economical model so small BYOK balances work out of the box.
# Per-pack model overrides can be layered in later.
RUN bash -lc "hermes config set model.default deepseek/deepseek-v4-flash" \
    || sed -i 's|^  default: .*|  default: "deepseek/deepseek-v4-flash"|' ~/.hermes/config.yaml

# Hermes API server port (controlled via API_SERVER_* env vars at runtime)
EXPOSE 8642

# Start the gateway; the OpenAI-compatible API server runs when API_SERVER_ENABLED=true
CMD ["bash", "-lc", "hermes -p default gateway"]
